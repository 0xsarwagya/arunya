{
    "name": "arunya",
    "version": "0.0.0-development",
    "private": true,
    "type": "module",
    "scripts": {
        "dev:tracker": "rolldown -c rolldown.config.ts -w",
        "dev:app": "next dev --turbopack",
        "dev": "NODE_ENV=development npm-run-all -p dev:tracker dev:app",
        "build:tracker": "rolldown -c rolldown.config.ts",
        "build:app": "NODE_ENV=production next build",
        "build:geo": "node scripts/build-geo.js",
        "build": "NODE_ENV=production npm run build:tracker && NODE_ENV=production npm run build:geo && NODE_ENV=production npm run build:app",
        "start": "NODE_ENV=production next start",
        "lint": "biome lint --write .",
        "lint:check": "biome lint .",
        "prepare": "husky",
        "cz": "cz",
        "db:migrate": "prisma migrate deploy",
        "db:generate": "prisma generate",
        "create-admin": "node scripts/create-admin.js",
        "type:check": "tsc --noEmit",
        "postinstall": "npm run db:migrate && npm run db:generate && npm run create-admin"
    },
    "dependencies": {
        "@prisma/client": "^6.0.1",
        "@radix-ui/react-icons": "1.3.2",
        "@radix-ui/react-slot": "^1.1.1",
        "better-auth": "^1.1.10",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "commitizen": "^4.3.1",
        "next": "^15.1.4",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "rolldown": "^1.0.0-beta.1",
        "tailwind-merge": "^2.5.5",
        "tailwindcss-animate": "^1.0.7"
    },
    "devDependencies": {
        "@biomejs/biome": "1.9.4",
        "@tailwindcss/typography": "0.5.15",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "cz-conventional-changelog": "^3.3.0",
        "dotenv": "^16.4.7",
        "esbuild": "^0.24.2",
        "husky": "9.1.7",
        "npm-run-all": "^4.1.5",
        "postcss": "^8",
        "prisma": "^6.2.0",
        "rollup-plugin-esbuild": "^6.1.1",
        "tailwindcss": "^3.4.1",
        "tar": "^7.4.3",
        "typescript": "^5",
        "zod": "3.24.1"
    },
    "config": {
        "commitizen": {
            "path": "./node_modules/cz-conventional-changelog"
        }
    }
}
